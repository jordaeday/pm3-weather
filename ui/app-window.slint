export component MainWindow inherits Window {
    in property <float> temperature;
    in property <string> city-name: "Seattle";
    height: 800px;
    in property <int> weather-code: 0;
    width: 960px;
    in property <string> state-name: "Washington";
    in property <string> time: "00:00:00";
    in-out property <color> sky-top: #ff0000;
    in-out property <color> sky-bottom: #0000ff;

    always-on-top: false;

    animate sky-top {
        duration: 1000ms;
        easing: ease-in-out;
    }

    animate sky-bottom {
        duration: 1000ms;
        easing: ease-in-out;
    }

    // Set background
    Rectangle {
        x: 0;
        y: 0;
        width: root.width;
        height: root.height;
        background: @linear-gradient(180deg, sky-top 0%, sky-bottom 50%);
    }

    VerticalLayout {
        // Top rectangle
        Rectangle {
            vertical-stretch: 1;
            background: transparent;

            VerticalLayout {
                alignment: center;
                spacing: 8px;
                
                Text {
                    text: city-name + ", " + state-name;
                    color: white;
                    font-size: 24px;
                    horizontal-alignment: center;
                }

                Text {
                    text: time;
                    color: white;
                    font-size: 100px;
                    horizontal-alignment: center;
                }
            }
        }

        // Divider line
        HorizontalLayout {
            alignment: center;
            Rectangle {
                background: white;
                width: 80%;
                height: 2px;
            }
        }

        // Bottom rectangles container
        HorizontalLayout {
            vertical-stretch: 1;
            // Bottom left rectangle
            Rectangle {
                background: transparent;

                VerticalLayout {
                    alignment: center;
                    spacing: 8px;

                    Text {
                        text: temperature + "°F";
                        color: white;
                        font-size: 100px;
                        horizontal-alignment: center;
                    }
                }
            }

            // Divider line
            VerticalLayout {
                alignment: start;
                Rectangle {
                    background: white;
                    width: 2px;
                    height: 80%;
                }
            }

            // Bottom right rectangle
            Rectangle {
                background: transparent;

                VerticalLayout {
                    alignment: center;
                    spacing: 8px;

                    Text {
                        text: "Weather Code: " + weather-code;
                        color: white;
                        font-size: 24px;
                        horizontal-alignment: center;
                    }
                }
            }
        }
    }
}
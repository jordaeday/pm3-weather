export component MainWindow inherits Window {
    in property <float> temperature;
    in property <string> city-name: "Seattle";
    in property <int> weather-code: 0;
    in property <string> state-name: "Washington";
    in property <string> time: "00:00:00";

    always-on-top: false;
    background: black;

    VerticalLayout {
    // Top rectangle
        Rectangle {
            VerticalLayout {
                alignment: center;
                spacing: 8px;
                
                Text {
                    text: city-name + ", " + state-name;
                    color: white;
                    font-size: 24px;
                    horizontal-alignment: center;
                }

                Text {
                    text: time;
                    color: white;
                    font-size: 100px;
                    horizontal-alignment: center;
                }
            }
        }

        // Bottom rectangles container
        HorizontalLayout {
            // Bottom left rectangle
            Rectangle {
                background: red;

                VerticalLayout {
                    alignment: center;
                    spacing: 8px;

                    Text {
                        text: temperature + "°F";
                        color: white;
                        font-size: 100px;
                        horizontal-alignment: center;
                    }
                }
            }

            // Bottom right rectangle
            Rectangle {
                background: blue;

                VerticalLayout {
                    alignment: center;
                    spacing: 8px;

                    Text {
                        text: "Weather Code: " + weather-code;
                        color: white;
                        font-size: 24px;
                        horizontal-alignment: center;
                    }
                }
            }
        }
    }
}
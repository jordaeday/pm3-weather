import { TabWidget } from "std-widgets.slint";
export component MainWindow inherits Window {
    in property <float> temperature;
    in property <string> city-name: "Seattle";
    in property <int> weather-code: 0;
    in property <string> state-name: "Washington";
    in property <string> date;
    in property <string> time: "00:00:00";
    in property <string> conditions: "Clear";
    in-out property <color> sky-top: #ff0000;
    in-out property <color> sky-bottom: #0000ff;

    always-on-top: false;

    animate sky-top {
        duration: 1000ms;
        easing: ease-in-out;
    }

    animate sky-bottom {
        duration: 1000ms;
        easing: ease-in-out;
    }

    // Set background
    Rectangle {
        x: 0;
        y: 0;
        width: root.width;
        height: root.height;
        background: @linear-gradient(180deg, sky-top 0%, sky-bottom 50%);
    }

    // Dark overlay for readability
    Rectangle {
        x: 0;
        y: 0;
        width: 100%;
        height: 100%;
        background: #000000aa;
    }

    // Screen layout
    VerticalLayout {
        padding: 20px;

        VerticalLayout {
            // Top rectangle
            Rectangle {
                vertical-stretch: 1;
                background: transparent;

                VerticalLayout {
                    alignment: center;
                    spacing: 8px;
                    
                    Text {
                        text: city-name + ", " + state-name;
                        color: #ffffffaa;
                        font-size: 24px;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: time;
                        color: white;
                        font-size: 100px;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: date;
                        color: #ffffffaa;
                        font-size: 24px;
                        horizontal-alignment: center;
                    }
                }
            }

            // Divider line
            Rectangle {
                background: white;
                height: 1px;
                width: 80%;
            }

            // Bottom rectangles container
            HorizontalLayout {
                vertical-stretch: 1;

                // Bottom left rectangle


                VerticalLayout {
                    alignment: center;
                    width: 50%;
                    spacing: 15px;

                    Text {
                        text: "TEMP";
                        color: #ffffff99;
                        font-size: 24px;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: temperature + "°F";
                        color: white;
                        font-size: 80px;
                        horizontal-alignment: center;
                    }
                }

                // Divider line
                VerticalLayout {
                    Rectangle {
                        background: white;
                        width: 1px;
                        height: 90%;
                    }
                }

                // Bottom right rectangle
                VerticalLayout {
                    alignment: center;
                    width: 50%;
                    spacing: 15px;

                    Text {
                        text: "CONDITIONS";
                        color: #ffffff99;
                        font-size: 24px;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: conditions;
                        color: white;
                        font-size: 60px;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                }
            }
        }
    }
}